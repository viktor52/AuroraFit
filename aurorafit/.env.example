DATABASE_URL="postgresql://aurorafit:aurorafit_password@localhost:5432/aurorafit?schema=public"

# Optional: Upstash Redis for accurate API rate limiting in middleware (multi-instance / Edge).
# Without these, a simple in-memory limiter applies (best on a single Node server).
# https://console.upstash.com/
# UPSTASH_REDIS_REST_URL="https://....upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# Optional: extra secret mixed into coach invite key digests (recommended in production).
# COACH_INVITE_PEPPER="long-random-string"

# Required to call POST /api/admin/coach-invite-keys (admins use this to mint coach keys).
ADMIN_SETUP_SECRET="change-me-to-a-long-random-secret"

# API Ninjas (Exercises API)
# https://www.api-ninjas.com/api/exercises
API_NINJAS_KEY="your-api-ninjas-key"

# Optional: YouTube Data API v3 key — resolves demo videos for in-page iframe embeds (search by exercise name).
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=""

# Optional: Invidious instance origin (no trailing slash) — fallback to resolve YouTube video ids for embeds
# when YOUTUBE_API_KEY is not set. Example: https://invidious.projectsegfau.lt
INVIDIOUS_API_ORIGIN=""

